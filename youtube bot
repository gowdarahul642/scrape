        self.single_btn.grid(row=2, column=0, columnspan=2, pady=(14, 4))

    # ── Search & Batch tab ────────────────────────────────────────────────────
    def _build_search_tab(self):
        tab = tk.Frame(self.nb, padx=14, pady=10)
        self.nb.add(tab, text="  Search & Download  ")

        tk.Label(tab, text="Search query:", font=("Helvetica", 11)).grid(
            row=0, column=0, sticky="w")
        self.search_var = tk.StringVar()
        tk.Entry(tab, textvariable=self.search_var, width=50,
                 font=("Helvetica", 11)).grid(row=0, column=1, padx=(8, 0))

        tk.Label(tab, text="e.g.  sad indian songs  •  lofi hindi  •  AR Rahman hits",
                 font=("Helvetica", 9), fg="#888").grid(
                     row=1, column=0, columnspan=2, sticky="w", pady=(2, 0))

        tk.Label(tab, text="Max results:", font=("Helvetica", 11)).grid(
            row=2, column=0, sticky="w", pady=(10, 0))
        self.max_results_var = tk.IntVar(value=20)
        tk.Spinbox(tab, from_=1, to=100, textvariable=self.max_results_var,
                   width=6, font=("Helvetica", 11)).grid(
                       row=2, column=1, sticky="w", padx=(8, 0), pady=(10, 0))

        tk.Label(tab, text="Max duration:", font=("Helvetica", 11)).grid(
            row=3, column=0, sticky="w", pady=(10, 0))
        df = tk.Frame(tab)
        df.grid(row=3, column=1, sticky="w", padx=(8, 0), pady=(10, 0))
        self.max_dur_var = tk.IntVar(value=10)
        tk.Spinbox(df, from_=1, to=180, textvariable=self.max_dur_var,
                   width=5, font=("Helvetica", 11)).pack(side="left")
        tk.Label(df, text=" min  (longer tracks skipped)",
                 font=("Helvetica", 9), fg="#888").pack(side="left")

        tk.Label(tab, text="Format: Audio only (m4a)  •  metadata embedded",
                 font=("Helvetica", 9), fg="#888").grid(
                     row=4, column=0, columnspan=2, sticky="w", pady=(6, 0))

        self.search_btn = tk.Button(tab, text="  🔍  Search & Download  ",
                                    command=self._start_search,
                                    bg="#FF0000", fg="white",
                                    activebackground="#cc0000",
                                    font=("Helvetica", 12, "bold"),
                                    relief="flat", cursor="hand2", pady=5)
        self.search_btn.grid(row=5, column=0, columnspan=2, pady=(14, 4))

    # ── Genre Automation tab ──────────────────────────────────────────────────
    def _build_genre_tab(self):
        tab = tk.Frame(self.nb, padx=10, pady=8)
        self.nb.add(tab, text="  🎵 Genre Automation  ")

        # top controls row
        ctrl = tk.Frame(tab)
        ctrl.pack(fill="x")

        tk.Label(ctrl, text="Songs per genre:", font=("Helvetica", 11)).pack(side="left")
        self.spg_var = tk.IntVar(value=20)
        tk.Spinbox(ctrl, from_=5, to=100, textvariable=self.spg_var,
                   width=5, font=("Helvetica", 11)).pack(side="left", padx=(6, 18))

        tk.Label(ctrl, text="Max duration:", font=("Helvetica", 11)).pack(side="left")
        self.genre_dur_var = tk.IntVar(value=10)
        tk.Spinbox(ctrl, from_=1, to=60, textvariable=self.genre_dur_var,
                   width=4, font=("Helvetica", 11)).pack(side="left", padx=(6, 4))
        tk.Label(ctrl, text="min", font=("Helvetica", 10), fg="#888").pack(side="left", padx=(0, 18))

        self.est_label = tk.Label(ctrl, text="", font=("Helvetica", 10, "bold"), fg="#0055cc")
        self.est_label.pack(side="left")

        # select / deselect all row
        btn_row = tk.Frame(tab)
        btn_row.pack(fill="x", pady=(6, 2))
        tk.Button(btn_row, text="✔ Select All", command=self._select_all_genres,
                  font=("Helvetica", 9), relief="flat", bg="#ddeedd",
                  cursor="hand2").pack(side="left", padx=(0, 6))
        tk.Button(btn_row, text="✖ Deselect All", command=self._deselect_all_genres,
                  font=("Helvetica", 9), relief="flat", bg="#ffdddd",
                  cursor="hand2").pack(side="left")
        tk.Label(btn_row,
                 text="  Each genre is saved in its own subfolder",
                 font=("Helvetica", 9), fg="#888").pack(side="left", padx=(12, 0))

        # scrollable checklist
        list_frame = tk.Frame(tab, relief="sunken", bd=1)
        list_frame.pack(fill="both", expand=True, pady=(4, 6))

        canvas = tk.Canvas(list_frame, height=220, bg="white", highlightthickness=0)
        vsb    = ttk.Scrollbar(list_frame, orient="vertical", command=canvas.yview)
        canvas.configure(yscrollcommand=vsb.set)
        vsb.pack(side="right", fill="y")
        canvas.pack(side="left", fill="both", expand=True)

        inner = tk.Frame(canvas, bg="white")
        canvas.create_window((0, 0), window=inner, anchor="nw")

        COLS = 3
        self._genre_vars = []
        for i, (name, query) in enumerate(GENRE_PRESETS):
            var = tk.BooleanVar(value=True)
            var.trace_add("write", lambda *_: self._update_estimate())
            cb = tk.Checkbutton(inner, text=name, variable=var,
                                bg="white", anchor="w",
                                font=("Helvetica", 10), cursor="hand2")
            cb.grid(row=i // COLS, column=i % COLS, sticky="w", padx=8, pady=1)
            self._genre_vars.append((var, name, query))

        inner.update_idletasks()
        canvas.configure(scrollregion=canvas.bbox("all"))

        def _on_wheel(e):
            canvas.yview_scroll(int(-1 * (e.delta / 120)), "units")
        canvas.bind("<MouseWheel>", _on_wheel)

        # start button
        self.genre_btn = tk.Button(tab, text="  🎵  Start Genre Automation  ",
                                   command=self._start_genre,
                                   bg="#FF0000", fg="white",
                                   activebackground="#cc0000",
                                   font=("Helvetica", 12, "bold"),
                                   relief="flat", cursor="hand2", pady=6)
        self.genre_btn.pack(pady=(4, 0))

        # wire up estimate updates
        self.spg_var.trace_add("write", lambda *_: self._update_estimate())
        self._update_estimate()

    # ── Estimate label ────────────────────────────────────────────────────────
    def _update_estimate(self):
        try:
            selected = sum(1 for v, _, _ in self._genre_vars if v.get())
            spg      = self.spg_var.get()
            self.est_label.config(
                text=f"≈ {selected * spg} songs  ({selected} genres × {spg})"
            )
        except Exception:
            pass

    def _select_all_genres(self):
        for v, _, _ in self._genre_vars:
            v.set(True)

    def _deselect_all_genres(self):
        for v, _, _ in self._genre_vars:
            v.set(False)

    # ── Folder picker ─────────────────────────────────────────────────────────
    def _pick_folder(self):
        folder = filedialog.askdirectory(title="Choose download folder",
                                          initialdir=self.save_folder)
        if folder:
            self.save_folder = folder
            self.folder_var.set(folder)

    # ── Single download ───────────────────────────────────────────────────────
    def _start_single(self):
        url = self.url_var.get().strip()
        if not url:
            messagebox.showwarning("No URL", "Please paste a YouTube URL first.")
            return
        self._prepare_ui([self.single_btn, self.search_btn, self.genre_btn])
        self._log(f"Saving to: {self.save_folder}")
        threading.Thread(
            target=download_single,
            args=(url, self.quality_var.get(), self.save_folder,
                  self._log, self._done),
            daemon=True,
        ).start()

    # ── Search download ───────────────────────────────────────────────────────
    def _start_search(self):
        query = self.search_var.get().strip()
        if not query:
            messagebox.showwarning("No query", "Please enter a search term.")
            return
        max_r   = self.max_results_var.get()
        max_dur = self.max_dur_var.get()
        self._stop_event.clear()
        self._prepare_ui([self.single_btn, self.search_btn, self.genre_btn])
        threading.Thread(
            target=search_and_download,
            args=(query, max_r, max_dur, self.save_folder,
                  self._log, self._done, self._stop_event),
            daemon=True,
        ).start()

    # ── Genre automation ──────────────────────────────────────────────────────
    def _start_genre(self):
        selected = [(name, q) for v, name, q in self._genre_vars if v.get()]
        if not selected:
            messagebox.showwarning("No genres", "Select at least one genre.")
            return
        spg     = self.spg_var.get()
        max_dur = self.genre_dur_var.get()
        est     = len(selected) * spg

        ok = messagebox.askyesno(
            "Start Genre Automation",
            f"About to download up to {est} songs\n"
            f"across {len(selected)} genres  ({spg} songs per genre).\n\n"
            f"Max duration  : {max_dur} min per track\n"
            f"Save folder   : {self.save_folder}\n\n"
            f"Each genre gets its own subfolder.\n\nProceed?"
        )
        if not ok:
            return

        self._stop_event.clear()
        self._prepare_ui([self.single_btn, self.search_btn, self.genre_btn])
        threading.Thread(
            target=genre_automation,
            args=(selected, spg, max_dur, self.save_folder,
                  self._log, self._done, self._stop_event),
            daemon=True,
        ).start()

    # ── Stop ──────────────────────────────────────────────────────────────────
    def _stop(self):
        self._stop_event.set()
        self._log("⏹  Stop requested — finishing current track …")
        self.stop_btn.config(state="disabled")

    # ── UI helpers ────────────────────────────────────────────────────────────
    def _prepare_ui(self, btns):
        self._log_clear()
        for b in btns:
            b.config(state="disabled")
        self.stop_btn.config(state="normal")
        self.progress.start(10)

    def _done(self, msg: str):
        self.after(0, lambda: self._finish(msg))

    def _finish(self, msg: str):
        self.progress.stop()
        self.single_btn.config(state="normal")
        self.search_btn.config(state="normal")
        self.genre_btn.config(state="normal")
        self.stop_btn.config(state="disabled")
        self._log(msg)
        if "✅" in msg or "complete" in msg.lower():
            messagebox.showinfo("Done!", msg[:300])
        else:
            messagebox.showerror("Failed", msg[:300])

    def _log(self, text: str):
        self.after(0, self._log_safe, text)

    def _log_safe(self, text: str):
        self.log.config(state="normal")
        self.log.insert("end", text + "\n")
        self.log.see("end")
        self.log.config(state="disabled")

    def _log_clear(self):
        self.log.config(state="normal")
        self.log.delete("1.0", "end")
        self.log.config(state="disabled")


