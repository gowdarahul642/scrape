# ── Helpers ───────────────────────────────────────────────────────────────────
def _fmt_duration(seconds):
    if seconds is None:
        return "?"
    h, rem = divmod(int(seconds), 3600)
    m, s   = divmod(rem, 60)
    return f"{h}:{m:02d}:{s:02d}" if h else f"{m}:{s:02d}"


def _safe_folder_name(name: str) -> str:
    """Strip characters illegal in folder names on Windows, Mac, and Linux."""
    for bad in r'/\\:*?"<>|':
        name = name.replace(bad, "-")
    name = " ".join(name.split()).strip(" -")
    return name or "genre"


# ── Core download functions ───────────────────────────────────────────────────
def download_single(url: str, quality: str, save_folder: str, log_fn, done_fn):
    format_map = {
        "Best quality":     "best[ext=mp4]/best",
        "1080p":            "best[height<=1080][ext=mp4]/best[height<=1080]/best",
        "720p":             "best[height<=720][ext=mp4]/best[height<=720]/best",
        "480p":             "best[height<=480][ext=mp4]/best[height<=480]/best",
        "Audio only (m4a)": "bestaudio[ext=m4a]/bestaudio",
    }
    ydl_opts = {
        "format":   format_map[quality],
        "outtmpl":  os.path.join(save_folder, "%(title)s.%(ext)s"),
        "quiet":    True,
        "no_warnings": True,
        "progress_hooks": [_make_hook(log_fn)],
    }
    try:
        with yt_dlp.YoutubeDL(ydl_opts) as ydl:
            info  = ydl.extract_info(url, download=True)
            title = info.get("title", "Unknown")
        done_fn(f'✅  Saved "{title}"\n    → {save_folder}')
    except Exception as exc:
        done_fn(f"❌  Error: {exc}")


def _download_query(query: str, max_results: int, max_duration_min: int,
                    save_folder: str, log_fn, stop_event):
    """
    Search YouTube for `query`, download audio for each result within duration limit.
    Returns (downloaded, skipped_long, failed).
    """
    max_sec    = max_duration_min * 60
    search_url = f"ytsearch{max_results}:{query}"
    downloaded = skipped_long = failed = 0

    ydl_opts = {
        "format":       "bestaudio[ext=m4a]/bestaudio/best",
        "outtmpl":      os.path.join(save_folder, "%(title)s.%(ext)s"),
        "quiet":        True,
        "no_warnings":  True,
        "ignoreerrors": True,
        "progress_hooks": [_make_hook(log_fn)],
        "postprocessors": [{"key": "FFmpegMetadata", "add_metadata": True}],
    }

    try:
        with yt_dlp.YoutubeDL(ydl_opts) as ydl:
            results = ydl.extract_info(search_url, download=False)
            entries = results.get("entries", []) if results else []

        for i, entry in enumerate(entries, 1):
            if stop_event.is_set():
                break
            if not entry:
                failed += 1
                continue

            title     = entry.get("title", f"Track {i}")
            duration  = entry.get("duration")
            video_url = entry.get("webpage_url") or entry.get("url")

            # Duration filter — skip playlists / long compilations
            if duration and duration > max_sec:
                log_fn(f"   ⏭  [{_fmt_duration(duration)}] SKIPPED  {title}")
                skipped_long += 1
                continue

            dur_label = f"[{_fmt_duration(duration)}] " if duration else ""
            log_fn(f"   ⬇  {dur_label}{title}")
            try:
                with yt_dlp.YoutubeDL(ydl_opts) as ydl2:
                    ydl2.download([video_url])
                downloaded += 1
                log_fn("      ✅  Done")
            except Exception as exc:
                failed += 1
                log_fn(f"      ❌  {exc}")

    except Exception as exc:
        log_fn(f"   ❌  Search error: {exc}")
        failed += 1

    return downloaded, skipped_long, failed


def search_and_download(query: str, max_results: int, max_duration_min: int,
                        save_folder: str, log_fn, done_fn, stop_event):
    os.makedirs(save_folder, exist_ok=True)
    log_fn(f"🔍  Searching: \"{query}\"  (up to {max_results} results)")
    log_fn(f"⏱  Max duration: {max_duration_min} min  |  📁  {save_folder}")
    log_fn("─" * 55)
    dl, sk, fa = _download_query(query, max_results, max_duration_min,
                                  save_folder, log_fn, stop_event)
    stopped = "  (stopped)" if stop_event.is_set() else ""
    done_fn(
        f"\n{'─'*55}\n"
        f"✅  Done{stopped}\n"
        f"   Downloaded : {dl}\n"
        f"   Too long   : {sk}  (>{max_duration_min} min)\n"
        f"   Failed     : {fa}\n"
        f"📁  {save_folder}"
    )


def genre_automation(genres: list, songs_per_genre: int, max_duration_min: int,
                     base_folder: str, log_fn, done_fn, stop_event):
    """
    Iterate over (genre_name, query) pairs.
    Each genre is saved into base_folder/<genre_name>/ subfolder.
    """
    total_dl = total_sk = total_fa = 0
    n = len(genres)

    log_fn("🎵  Genre Automation started")
    log_fn(f"   Genres      : {n}")
    log_fn(f"   Songs/genre : {songs_per_genre}")
    log_fn(f"   Max duration: {max_duration_min} min per track")
    log_fn(f"   Base folder : {base_folder}")
    log_fn("═" * 55)

    for idx, (name, query) in enumerate(genres, 1):
        if stop_event.is_set():
            log_fn("\n⏹  Stopped by user.")
            break

        folder = os.path.join(base_folder, _safe_folder_name(name))
        os.makedirs(folder, exist_ok=True)

        log_fn(f"\n[{idx}/{n}]  🎸  {name}")
        log_fn(f"   Query  : {query}")
        log_fn(f"   Folder : …/{_safe_folder_name(name)}")

        dl, sk, fa = _download_query(query, songs_per_genre, max_duration_min,
                                      folder, log_fn, stop_event)
        total_dl += dl
        total_sk += sk
        total_fa += fa
        log_fn(f"   ── Genre done  ✅ {dl} downloaded  ⏭ {sk} skipped  ❌ {fa} failed")

    stopped = "  (stopped early)" if stop_event.is_set() else ""
    done_fn(
        f"\n{'═'*55}\n"
        f"🎵  Genre Automation complete{stopped}\n"
        f"   Total downloaded  : {total_dl}\n"
        f"   Too long skipped  : {total_sk}\n"
        f"   Failed            : {total_fa}\n"
        f"📁  {base_folder}"
    )


def _make_hook(log_fn):
    def hook(d):
        if d["status"] == "downloading":
            pct   = d.get("_percent_str", "").strip()
            speed = d.get("_speed_str",   "").strip()
            eta   = d.get("_eta_str",     "").strip()
            log_fn(f"      {pct}  {speed}  ETA {eta}")
        elif d["status"] == "finished":
            log_fn("      ⚙  Processing …")
    return hook


