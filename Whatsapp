import time
import threading
from datetime import datetime

import pytz
import tkinter as tk
from tkinter import ttk, messagebox

from selenium import webdriver
from selenium.webdriver.chrome.service import Service
from selenium.webdriver.common.by import By
from selenium.webdriver.common.keys import Keys
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
from selenium.common.exceptions import WebDriverException, TimeoutException
from webdriver_manager.chrome import ChromeDriverManager

# ─────────────────────────────────────────────
# CONFIGURATION
# ─────────────────────────────────────────────
TIMEZONE = "Asia/Kolkata"          # Change if needed
QR_SCAN_TIMEOUT = 60               # Seconds to wait for WhatsApp QR scan
MESSAGE_LOAD_TIMEOUT = 20          # Seconds to wait for chat to load
# ─────────────────────────────────────────────


def launch_driver() -> webdriver.Chrome:
    """Launch Chrome with WhatsApp Web and wait for QR scan."""
    options = webdriver.ChromeOptions()
    options.add_argument("--start-maximized")
    options.add_argument("--disable-notifications")
    # Persist Chrome profile so you don't re-scan QR every time:
    options.add_argument("--user-data-dir=./whatsapp_chrome_profile")

    driver = webdriver.Chrome(
        service=Service(ChromeDriverManager().install()),
        options=options
    )
    driver.get("https://web.whatsapp.com/")
    print("Waiting for WhatsApp QR scan…")

    try:
        # Wait until the search box appears — confirms login is complete
        WebDriverWait(driver, QR_SCAN_TIMEOUT).until(
            EC.presence_of_element_located(
                (By.XPATH, '//div[@contenteditable="true"][@data-tab="3"]')
            )
        )
        print("WhatsApp Web loaded successfully.")
    except TimeoutException:
        messagebox.showerror(
            "Timeout",
            f"QR code not scanned within {QR_SCAN_TIMEOUT} seconds. Please restart."
        )
        driver.quit()
        raise

    return driver


def send_whatsapp_message(driver: webdriver.Chrome, contact: str, message: str) -> None:
    """Search for a contact and send a message."""
    wait = WebDriverWait(driver, MESSAGE_LOAD_TIMEOUT)

    # Click the search box and type the contact name
    search_box = wait.until(
        EC.element_to_be_clickable(
            (By.XPATH, '//div[@contenteditable="true"][@data-tab="3"]')
        )
    )
    search_box.clear()
    search_box.send_keys(contact)
    time.sleep(1.5)  # Allow search results to populate

    # Click the first matching result
    first_result = wait.until(
        EC.element_to_be_clickable(
            (By.XPATH, f'//span[@title="{contact}"]')
        )
    )
    first_result.click()
    time.sleep(1)

    # Type and send the message
    message_box = wait.until(
        EC.element_to_be_clickable(
            (By.XPATH, '//div[@contenteditable="true"][@data-tab="10"]')
        )
    )
    message_box.click()
    message_box.send_keys(message)
    message_box.send_keys(Keys.ENTER)
    print(f"Message sent to '{contact}': {message}")


def schedule_and_send(contact: str, message: str, send_time_str: str,
                      driver: webdriver.Chrome, status_var: tk.StringVar) -> None:
    """
    Run in a background thread.
    Sleeps until the scheduled time, then sends the message.
    """
    ist = pytz.timezone(TIMEZONE)

    try:
        naive_time = datetime.strptime(send_time_str, "%H:%M")
    except ValueError:
        status_var.set("Invalid time format. Use HH:MM.")
        return

    send_dt = ist.localize(datetime.combine(datetime.today(), naive_time.time()))
    now = datetime.now(ist)
    delay = (send_dt - now).total_seconds()

    if delay <= 0:
        status_var.set("Please enter a future time.")
        return

    mins = int(delay // 60)
    secs = int(delay % 60)
    status_var.set(f"Scheduled! Sending in {mins}m {secs}s…")
    print(f"Sleeping for {delay:.0f} seconds until {send_time_str} IST…")
    time.sleep(delay)

    try:
        send_whatsapp_message(driver, contact, message)
        status_var.set(f"Message sent to '{contact}' at {send_time_str}!")
    except Exception as exc:
        status_var.set(f"Error sending message: {exc}")
        print(f"Error: {exc}")


def on_schedule_click(contact_var: tk.StringVar, message_var: tk.StringVar,
                      time_var: tk.StringVar, driver: webdriver.Chrome,
                      status_var: tk.StringVar, btn: ttk.Button) -> None:
    """Validate inputs and start the scheduler thread."""
    contact = contact_var.get().strip()
    message = message_var.get().strip()
    send_time_str = time_var.get().strip()

    if not contact:
        messagebox.showwarning("Missing Input", "Please enter a contact name.")
        return
    if not message:
        messagebox.showwarning("Missing Input", "Please enter a message.")
        return
    if not send_time_str:
        messagebox.showwarning("Missing Input", "Please enter a send time.")
        return

    # Disable button to prevent double-scheduling
    btn.config(state="disabled")
    status_var.set("Scheduling…")

    thread = threading.Thread(
        target=schedule_and_send,
        args=(contact, message, send_time_str, driver, status_var),
        daemon=True
    )
    thread.start()


def build_gui(driver: webdriver.Chrome) -> None:
    """Build and launch the Tkinter GUI."""
    root = tk.Tk()
    root.title("WhatsApp Message Scheduler")
    root.resizable(False, False)

    pad = {"padx": 12, "pady": 6}

    ttk.Label(root, text="Contact Name:").grid(row=0, column=0, sticky="e", **pad)
    contact_var = tk.StringVar()
    ttk.Entry(root, textvariable=contact_var, width=30).grid(row=0, column=1, **pad)

    ttk.Label(root, text="Message:").grid(row=1, column=0, sticky="e", **pad)
    message_var = tk.StringVar()
    ttk.Entry(root, textvariable=message_var, width=30).grid(row=1, column=1, **pad)

    ttk.Label(root, text="Send Time (HH:MM, IST):").grid(row=2, column=0, sticky="e", **pad)
    time_var = tk.StringVar()
    ttk.Entry(root, textvariable=time_var, width=10).grid(row=2, column=1, sticky="w", **pad)

    status_var = tk.StringVar(value="Enter details and schedule a message.")
    ttk.Label(root, textvariable=status_var, foreground="gray").grid(
        row=4, column=0, columnspan=2, **pad
    )

    btn = ttk.Button(root, text="Schedule Message")
    btn.config(
        command=lambda: on_schedule_click(
            contact_var, message_var, time_var, driver, status_var, btn
        )
    )
    btn.grid(row=3, column=0, columnspan=2, pady=10)

    root.mainloop()


# ── Entry point ───────────────────────────────────────────────────────────────
if __name__ == "__main__":
    try:
        driver = launch_driver()
        build_gui(driver)
    except WebDriverException as e:
        print(f"WebDriver error: {e}")
    except Exception as e:
        print(f"Unexpected error: {e}")
    finally:
        try:
            driver.quit()
        except Exception:
            pass
